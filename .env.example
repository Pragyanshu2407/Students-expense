# =============================================================================
# .env.example — copy this file to .env and fill in real values.
#
#   cp .env.example .env
#
# NEVER commit .env to git.  .env.example is safe to commit because it
# contains only placeholder values, not real credentials.
# =============================================================================

# ── Flask ─────────────────────────────────────────────────────────────────────

# "production" or "development"
FLASK_ENV=production

# Must be a long, random string in production.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# ── PostgreSQL ────────────────────────────────────────────────────────────────

POSTGRES_DB=expense_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-strong-password

# Full connection URL — references the variables above.
# "db" is the docker-compose service name; Docker's internal DNS resolves it.
DATABASE_URL=postgresql://postgres:change-this-strong-password@db:5432/expense_tracker

# ── Admin account (seeded on first boot) ─────────────────────────────────────

# Password for the default admin account created on first run.
# Change this before deploying!
ADMIN_PASSWORD=change-this-admin-password

# ── Gunicorn ──────────────────────────────────────────────────────────────────

# Number of worker processes.  Recommended: (2 x CPU cores) + 1
GUNICORN_WORKERS=2

# Threads per worker.  Good for I/O-bound apps (DB queries).
GUNICORN_THREADS=2

# Seconds before killing a stuck worker
GUNICORN_TIMEOUT=60

# ── Logging ───────────────────────────────────────────────────────────────────

# Gunicorn + app log level: debug | info | warning | error | critical
LOG_LEVEL=info
